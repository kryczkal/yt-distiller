# yt-distill backend config. Copy to .env and fill in what you need.
# .env is gitignored — your secrets stay local. Loaded by the native host on launch.

# --- Gemini visual fallback (optional) ---
# Free key (no card): https://aistudio.google.com/apikey
# Enables the "watch the video" path for no-caption / visual-heavy PUBLIC videos
# (auto-fallback when a video has no captions, and the side-panel "⟳ video" button).
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- Backend (all optional; sensible defaults shown) ---
# YT_DISTILL_MODEL=claude-sonnet-4-6     # Claude model for transcript distillation
# YT_DISTILL_COOKIES_FROM_BROWSER=brave  # reuse browser cookies for age-gated/region-locked videos

# Do NOT set ANTHROPIC_API_KEY here — it overrides your Claude subscription and
# bills you per-token. The backend runs on your subscription by default.
